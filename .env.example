# Copy this file to .env and fill in real values. Never commit .env itself.

# Required: used by the LangGraph agent (gpt-4o-mini) for reasoning
OPENAI_API_KEY=sk-your-key-here

# Optional: only needed if you enable OpenRouteService walkability isochrones
ORS_API_KEY=

# URL of the FastMCP backend, used by the agent and (later) Streamlit.
# Local default shown; replace with the deployed Render URL in production.
MCP_SERVER_URL=http://127.0.0.1:8000

# Custom User-Agent required by Nominatim's usage policy — include real contact info
NOMINATIM_USER_AGENT=GeoScout/0.1 (contact: arahmanmdmajid@gmail.com)

# Optional: LangSmith tracing for the LangGraph agent. Leave LANGSMITH_TRACING
# unset/false to run without tracing (e.g. local dev without a LangSmith key).
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_your-key-here
LANGSMITH_PROJECT=geoscout
